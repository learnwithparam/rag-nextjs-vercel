# Default provider for /api/chat (direct streaming chat)
# OpenRouter works with one key for many models
CHAT_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# /api/rag uses Gemini's native urlContext tool - Google key REQUIRED to hit that route
GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key_here

# /api/rag2 uses Mistral embeddings + Gemini generation - both keys REQUIRED to hit that route
MISTRAL_API_KEY=your_mistral_api_key_here
